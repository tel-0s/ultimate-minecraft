/target
nul
# Anvil-format world saves (default `world/`, custom `--world <name>` dirs).
world/
world-*/
# Operator-local server config; auto-created on first run from
# crates/server/src/config.rs::DEFAULT_CONFIG_YAML.
/server.yaml
# Vanilla-comparison bench area: server.jar (54 MB), its world, logs.
# The driver scripts (*.ps1) ARE tracked — whitelisted below.
/bench_vanilla/*
!/bench_vanilla/drive.ps1
!/bench_vanilla/escalate.ps1
!/bench_vanilla/mega.ps1
# Load-test artifacts (logs + samplers)
10k*.log
10k*.csv
3k_*.log
3k_*.csv
world-10k/
